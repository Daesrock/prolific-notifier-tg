PROLIFIC_EMAIL=your_prolific_email@example.com
PROLIFIC_PASSWORD=your_prolific_password
TELEGRAM_BOT_TOKEN=123456789:your-telegram-bot-token
TELEGRAM_CHAT_ID=123456789
POLL_INTERVAL_MS=300000
