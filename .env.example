# POLL_INTERVAL_MIN_MS=360000
# POLL_INTERVAL_MAX_MS=540000
DATABASE_PATH=./data/prolific.db
SESSION_STATE_PATH=./data/prolific-session.json
SESSION_STATE_GZIP_BASE64=
SESSION_STATE_BASE64=
PROLIFIC_LOGIN_URL=https://app.prolific.com/login
PROLIFIC_STUDIES_URL=https://app.prolific.com/studies
HEADLESS=true
LOG_LEVEL=info
MAX_AUTH_RETRIES=3
ALERT_COOLDOWN_MS=900000
HEARTBEAT_INTERVAL_MS=3600000
